# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_ADMIN_WALLETS=0xAdminWallet1,0xAdminWallet2
ADMIN_SECRET=change-me
CRON_SECRET=change-me-too
WORKER_ROUTE_TIMEOUT_MS=240000
# On Vercel, set true when Railway owns private worker execution.
DISABLE_SCHEDULED_WORKERS=false
# Set on Vercel when admin/cron actions should proxy to the Railway worker.
WORKER_TRIGGER_URL=
WORKER_TRIGGER_SECRET=change-worker-trigger-secret

# Database (Supabase Postgres connection string)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/precall

# Arc Testnet
# Get the Canteen-hosted RPC after `arc-canteen login` with: `arc-canteen rpc-url`.
# Keep this server-side only; never expose the tokenized Canteen RPC as NEXT_PUBLIC_*.
ARC_TESTNET_RPC_URL=https://rpc.testnet.arc-node.thecanteenapp.com/v1/YOUR_ARC_CANTEEN_RPC_KEY
NEXT_PUBLIC_ARC_CHAIN_ID=5042002
PRECALL_REGISTRY_ADDRESS=
NEXT_PUBLIC_PRECALL_REGISTRY_ADDRESS=
PROTOCOL_TREASURY_ADDRESS=
ARC_USDC_ADDRESS=0x3600000000000000000000000000000000000000
NEXT_PUBLIC_ARC_USDC_ADDRESS=0x3600000000000000000000000000000000000000

# Worker / onchain publisher
RESOLVER_PRIVATE_KEY=
AGENT_OWNER_PRIVATE_KEY=
AGENT_OWNER_WALLET=
DEFAULT_ONCHAIN_AGENT_ID=
PUBLISH_ONCHAIN=true
RESOLVE_ONCHAIN=true

# AI agents (OpenAI-compatible providers supported)
# FreeModel example: OPENAI_BASE_URL=https://api.freemodel.dev/v1 and OPENAI_MODEL=gpt-5.4-mini.
# Do not use the Claude Code/Anthropic URL here; this worker calls /chat/completions.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4.1-mini
MODEL_TIMEOUT_MS=45000
MODEL_RETRY_COUNT=2

# Polymarket
POLYMARKET_GAMMA_URL=https://gamma-api.polymarket.com
POLYMARKET_CLOB_URL=https://clob.polymarket.com
POLYMARKET_BUILDER_CODE=

# Circle Gateway/x402 paid evidence (optional, real paid calls only when enabled)
# Uses a separate buyer key from AGENT_OWNER_PRIVATE_KEY. Never expose as NEXT_PUBLIC_*.
ENABLE_CIRCLE_GATEWAY_X402=false
CIRCLE_GATEWAY_CHAIN=arcTestnet
CIRCLE_AGENT_PRIVATE_KEY=
CIRCLE_GATEWAY_RPC_URL=
CIRCLE_X402_MAX_PAYMENT_USDC=0.005
CIRCLE_X402_DAILY_BUDGET_USDC=0.10
CIRCLE_X402_ALLOWED_HOSTS=api.aisa.one
CIRCLE_X402_MIN_GATEWAY_BALANCE_USDC=0.25

# Agent thresholds
MIN_LIQUIDITY_USD=10000
MIN_EDGE_BPS=650
MAX_SPREAD_BPS=900
MIN_CONFIDENCE_BPS=5200
MIN_SUGGESTED_SIZE_BPS=100
# Keep false for real use. True only lets publish-run bypass thresholds for explicit demos.
ALLOW_PUBLISH_FILTERED_RUN=false
MAX_MARKETS_PER_RUN=8
MAX_ANALYZED_MARKETS_PER_RUN=4
BOND_AMOUNT_USDC=1
UNLOCK_PRICE_USDC=0.05
