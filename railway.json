{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "npm -w @precall/shared run build && npm -w @precall/worker run build"
  },
  "deploy": {
    "startCommand": "npm run worker:serve",
    "healthcheckPath": "/healthz",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}
