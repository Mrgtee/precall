{
  "name": "precall-arena",
  "version": "0.1.0",
  "private": true,
  "description": "Arc-native prediction-market intelligence arena for autonomous market agents.",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "set -a; [ -f .env ] && . ./.env; set +a; npm run dev -w apps/web",
    "build": "set -a; [ -f .env ] && . ./.env; set +a; npm -w @precall/shared run build && npm -w @precall/worker run build && npm -w @precall/web run build",
    "build:all": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "worker": "npm run start -w apps/worker",
    "worker:serve": "npm run serve -w apps/worker",
    "worker:health": "npm run start -w apps/worker -- health",
    "worker:run-once": "npm run start -w apps/worker -- run-once",
    "worker:expire": "npm run start -w apps/worker -- expire",
    "worker:resolve": "npm run start -w apps/worker -- resolve",
    "db:generate": "drizzle-kit generate --config drizzle.config.ts",
    "db:migrate": "drizzle-kit migrate --config drizzle.config.ts",
    "contracts:test": "PATH=\"$HOME/.foundry/bin:$PATH\" forge test --root packages/contracts",
    "contracts:build": "PATH=\"$HOME/.foundry/bin:$PATH\" forge build --root packages/contracts",
    "arc:status": "PATH=\"$HOME/.local/bin:$PATH\" arc-canteen status",
    "arc:rpc": "PATH=\"$HOME/.local/bin:$PATH\" arc-canteen rpc-url",
    "arc:chain-id": "PATH=\"$HOME/.local/bin:$PATH\" arc-canteen rpc eth_chainId",
    "arc:context": "PATH=\"$HOME/.local/bin:$PATH\" arc-canteen context sync",
    "test": "TMPDIR=/tmp node --import tsx --test packages/shared/src/*.test.ts packages/shared/src/circle/*.test.ts packages/shared/src/evidence/*.test.ts packages/shared/src/evidence/providers/*.test.ts apps/web/lib/*.test.ts apps/worker/src/*.test.ts",
    "worker:x402:supports": "npm run start -w apps/worker -- x402:supports",
    "worker:gateway:balance": "npm run start -w apps/worker -- gateway:balance",
    "worker:gateway:deposit": "npm run start -w apps/worker -- gateway:deposit"
  },
  "devDependencies": {
    "drizzle-kit": "^0.31.1",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": "20.x"
  }
}
