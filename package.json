{
  "name": "precall-arena",
  "version": "0.1.0",
  "private": true,
  "description": "Arc-native prediction-market intelligence arena for autonomous market agents.",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "set -a; [ -f .env ] && . ./.env; set +a; npm run dev -w apps/web",
    "build": "set -a; [ -f .env ] && . ./.env; set +a; npm -w @precall/shared run build && npm -w @precall/worker run build && npm -w @precall/web run build",
    "build:all": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "worker": "npm run start -w apps/worker",
    "db:generate": "drizzle-kit generate --config drizzle.config.ts",
    "db:migrate": "drizzle-kit migrate --config drizzle.config.ts",
    "contracts:test": "PATH=\"$HOME/.foundry/bin:$PATH\" forge test --root packages/contracts",
    "contracts:build": "PATH=\"$HOME/.foundry/bin:$PATH\" forge build --root packages/contracts",
    "arc:status": "PATH=\"$HOME/.local/bin:$PATH\" arc-canteen status",
    "arc:rpc": "PATH=\"$HOME/.local/bin:$PATH\" arc-canteen rpc-url",
    "arc:chain-id": "PATH=\"$HOME/.local/bin:$PATH\" arc-canteen rpc eth_chainId",
    "arc:context": "PATH=\"$HOME/.local/bin:$PATH\" arc-canteen context sync"
  },
  "devDependencies": {
    "drizzle-kit": "^0.31.1",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": "20.x"
  }
}
